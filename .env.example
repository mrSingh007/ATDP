# ATDP Data Proxy configuration.
# The proxy expects an external OpenAI-compatible upstream provider.
# It does not install or run Ollama in Docker.

ATDP_PROVIDER=openai-compatible

# Host Ollama, when running the proxy locally:
# ATDP_UPSTREAM_BASE_URL=http://localhost:11434/v1

# Host Ollama, when running the proxy in Docker:
ATDP_UPSTREAM_BASE_URL=http://host.docker.internal:11434/v1

# OpenAI:
# ATDP_UPSTREAM_BASE_URL=https://api.openai.com/v1
# ATDP_UPSTREAM_API_KEY=sk-...

# Groq:
# ATDP_UPSTREAM_BASE_URL=https://api.groq.com/openai/v1
# ATDP_UPSTREAM_API_KEY=gsk_...

# AWS Bedrock via LiteLLM or another OpenAI-compatible gateway:
# ATDP_UPSTREAM_BASE_URL=http://host.docker.internal:4000/v1
# ATDP_UPSTREAM_API_KEY=...

ATDP_UPSTREAM_API_KEY=
ATDP_FORWARD_AUTHORIZATION=false
ATDP_DATA_DIR=./data
ATDP_REQUEST_TIMEOUT_SECONDS=120
ATDP_DEFAULT_TENANT_ID=default
ATDP_REDACTION_MODE=basic
ATDP_OTEL_ENABLED=false
ATDP_OTEL_SERVICE_NAME=atdp-data-proxy
ATDP_OTEL_EXPORTER_OTLP_ENDPOINT=
